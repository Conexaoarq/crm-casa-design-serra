generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// NEXTAUTH MODELS (Magic Link & Auth)
// ==========================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// CRM MODELS (Casa Design Serra)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Custom Fields for CRM
  companyName   String?
  phone         String?
  role          String    @default("MEMBER") // "MEMBER" or "ADMIN"
  password      String?   // Para login administrativo
  createdAt     DateTime  @default(now())
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  
  referralsGiven    Referral[] @relation("ReferralsGiven")
  referralsReceived Referral[] @relation("ReferralsReceived")
  auditLogs         AuditLog[]
}

model Referral {
  id             String   @id @default(cuid())
  
  fromUserId     String
  fromUser       User     @relation("ReferralsGiven", fields: [fromUserId], references: [id])
  
  toUserId       String?  // If null, it's an open referral to anyone in the group
  toUser         User?    @relation("ReferralsReceived", fields: [toUserId], references: [id])
  
  // Lead/Client details
  clientName     String
  clientPhone    String?
  projectDetails String?
  architectName  String?
  
  status         String   @default("PENDING") // PENDING, CONTACTED, QUOTED, CLOSED_WON, CLOSED_LOST
  contactMade    Boolean  @default(false)
  budgetGenerated Boolean @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  closedBusiness ClosedBusiness?
}

model ClosedBusiness {
  id          String   @id @default(cuid())
  
  referralId  String   @unique
  referral    Referral @relation(fields: [referralId], references: [id])
  
  value       Float    // O Valor em R$
  
  closedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  action    String   // "VIEW_REPORTS", "LOGIN", "CREATE_REFERRAL", etc
  details   String?  // JSON string or description
  
  createdAt DateTime @default(now())
}
